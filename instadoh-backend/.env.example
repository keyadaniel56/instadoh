# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ============================================
# DATABASE
# ============================================
# Use SQLite for development (zero config):
DB_DRIVER=sqlite
DB_PATH=instadoh.db

# Switch to PostgreSQL for production:
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=instadoh
# DB_PASSWORD=instadoh_secret
# DB_NAME=instadoh
# DB_SSLMODE=disable

# ============================================
# LIGHTNING NETWORK (LND)
# ============================================
# Option 1: Local LND node (default paths)
# LND_HOST=localhost:10009
# LND_TLS_CERT=/home/YOUR_USER/.lnd/tls.cert          # ← CHANGE this to your home dir
# LND_MACAROON=/home/YOUR_USER/.lnd/data/chain/bitcoin/mainnet/admin.macaroon

# Option 2: LND via Docker (run separately)
# LND_HOST=localhost:10009
# LND_TLS_CERT=/home/YOUR_USER/lnd/tls.cert
# LND_MACAROON=/home/YOUR_USER/lnd/admin.macaroon

# Option 3: Remote LND node (e.g., Voltage.cloud, LNBits)
# LND_HOST=your-node.voltageapp.io:10009
# LND_TLS_CERT=(paste the TLS cert hex string here)
# LND_MACAROON=(paste the admin macaroon hex string here)

# Option 4: Quick start with Polar (lnd docker testnet)
# https://lightningpolar.com/ - spin up a local test network
# LND_HOST=localhost:10001
# LND_TLS_CERT=/home/YOUR_USER/.polar/networks/1/volumes/lnd/alice/tls.cert
# LND_MACAROON=/home/YOUR_USER/.polar/networks/1/volumes/lnd/alice/data/chain/bitcoin/regtest/admin.macaroon

# ============================================
# EXCHANGE RATES
# ============================================
EXCHANGE_API_KEY=
EXCHANGE_BASE_URL=https://api.exchangerate-api.com/v4/latest
EXCHANGE_CACHE_TTL=300

# ============================================
# JWT AUTH
# ============================================
JWT_SECRET=change-me-to-a-very-long-and-secure-random-string
JWT_EXPIRATION_HOURS=24

# ============================================
# M-PESA (DARAJAS API) - KENYA
# ============================================
# Get credentials from https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com

# ============================================
# UGANDA MOBILE MONEY
# ============================================
UG_MOBILE_API_BASE_URL=https://api.uganda-mobile.co.ug/v1
UG_MOBILE_API_USERNAME=
UG_MOBILE_API_PASSWORD=
UG_MOBILE_CALLBACK_URL=https://your-domain.com