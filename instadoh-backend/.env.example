# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=instadoh
DB_PASSWORD=instadoh_secret
DB_NAME=instadoh
DB_SSLMODE=disable

# Lightning Network Daemon (LND)
LND_HOST=localhost:10009
LND_TLS_CERT=/root/.lnd/tls.cert
LND_MACAROON=/root/.lnd/data/chain/bitcoin/mainnet/admin.macaroon

# Exchange Rate API
EXCHANGE_API_KEY=
EXCHANGE_BASE_URL=https://api.exchangerate-api.com/v4/latest
EXCHANGE_CACHE_TTL=300

# JWT
JWT_SECRET=change-me-to-a-very-long-and-secure-random-string
JWT_EXPIRATION_HOURS=24